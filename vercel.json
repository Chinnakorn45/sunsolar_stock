{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "env": {
    "VITE_API_BASE": "https://sunsolar-stock.onrender.com"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sunsolar-stock.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
