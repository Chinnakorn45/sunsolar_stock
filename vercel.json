{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "env": {
    "VITE_API_BASE": "@vite-api-base"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ep-rapid-base-aoc1z09g.apirest.c-2.ap-southeast-1.aws.neon.tech/neondb/rest/v1:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
